[Unit]
Description=MM Squeeze & Unwind Detection Strategy Bot
After=network.target

[Service]
Type=simple
User=gpt
WorkingDirectory=/home/gpt/mm-strategy-bot
EnvironmentFile=/home/gpt/mm-strategy-bot/.env
ExecStart=/home/gpt/mm-strategy-bot/venv/bin/python main.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
